# ============================================================================
#  .gitignore — North Star Support Bot (monorepo)
# ----------------------------------------------------------------------------
#  Primary stack: Node.js (Express) + React (Vite + Tailwind).
#  Python sections are included defensively in case tooling/tests are added.
# ============================================================================

# ---- Dependencies ----------------------------------------------------------
# Node
node_modules/
jspm_packages/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- Build output ----------------------------------------------------------
# Node / Vite
dist/
dist-ssr/
*.local
.vite/

# Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---- Environments & secrets ------------------------------------------------
.env
.env.*
!.env.example
.env.local
.env.*.local

# Python virtualenvs (common names)
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ---- Testing & coverage ----------------------------------------------------
# Python
.tox/
.nox/
.pytest_cache/
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Node
coverage/
*.lcov

# ---- Logs ------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# ---- Editor / IDE ----------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/

# ---- Operating system ------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ---- Misc ------------------------------------------------------------------
.eslintcache
.stylelintcache
.parcel-cache
.next/
out/
tsconfig.tsbuildinfo
